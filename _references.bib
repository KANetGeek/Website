  shorttitle = {Shapeshifting to Address Complexity},
  author = {Albrecht, Kate},
  date = {2022-04-12},
  journaltitle = {Complexity, Governance \& Networks},
  shortjournal = {CGN},
  volume = {8},
  number = {1},
